configuration {
    font: "Fira Code Nerd Font Mono 12";
    show-icons: true;
    timeout {
        action: "kb-cancel";
        delay:  0;
    }
    filebrowser {
        directories-first: true;
        sorting-method:    "name";
    }
    icon-theme: "Papirus";
}

@theme "~/.config/rofi/theme.rasi"